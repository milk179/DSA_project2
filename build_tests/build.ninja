build _deps/catch2-build/src/libCatch2Main.a: CXX_STATIC_LIBRARY_LINKER__Catch2WithMain_Release _deps/catch2-build/src/CMakeFiles/Catch2WithMain.dir/catch2/internal/catch_main.cpp.obj || _deps/catch2-build/src/libCatch2.a
  LANGUAGE_COMPILE_FLAGS = -O3 -DNDEBUG
  OBJECT_DIR = _deps\catch2-build\src\CMakeFiles\Catch2WithMain.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_FILE = _deps\catch2-build\src\libCatch2Main.a
  TARGET_PDB = Catch2Main.a.dbg


#############################################
# Utility command for test

build _deps/catch2-build/src/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D C:\Users\jonat\DSA_project2\build_tests\_deps\catch2-build\src && C:\mingw64\bin\ctest.exe --force-new-ctest-process "
  DESC = Running tests...
  pool = console
  restat = 1

build _deps/catch2-build/src/test: phony _deps/catch2-build/src/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build _deps/catch2-build/src/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D C:\Users\jonat\DSA_project2\build_tests\_deps\catch2-build\src && C:\mingw64\bin\cmake.exe -E echo "No interactive CMake dialog available.""
  DESC = No interactive CMake dialog available...
  restat = 1

build _deps/catch2-build/src/edit_cache: phony _deps/catch2-build/src/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build _deps/catch2-build/src/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D C:\Users\jonat\DSA_project2\build_tests\_deps\catch2-build\src && C:\mingw64\bin\cmake.exe --regenerate-during-build -SC:\Users\jonat\DSA_project2 -BC:\Users\jonat\DSA_project2\build_tests"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build _deps/catch2-build/src/rebuild_cache: phony _deps/catch2-build/src/CMakeFiles/rebuild_cache.util

